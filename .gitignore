# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# local admin datastore (can contain PII)
/data/nairatag-admin.json
/data/*.corrupt-*

# Botpress build artifacts
/botpress-agent/nairatag-agent/.botpress/
/botpress-agent/nairatag-agent/node_modules/
/botpress-agent/brunch24-agent/.botpress/
/botpress-agent/brunch24-agent/node_modules/
/botpress-agent/brunch24-agent/*.log
/botpress-agent/brunch24-agent/*.pid

# local sandboxes
/Brunch24-AI/

# local tools
/tools/mingit/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-dev.err.log
.next-dev.log
.next-dev.out.log
.local-logs/

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
